# ===== 데이터 소스 =====
# dummy = 인메모리 더미(기본, DB 없이 데모 가능) | db = PostgreSQL
DATA_SOURCE=dummy

# ===== PostgreSQL (DATA_SOURCE=db 일 때) =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sorisak
DB_USER=sorisak_user
DB_PASSWORD=your_password_here

# ===== OpenAI GPT (단어 selector / 문법 보정 / 리포트 해석) =====
# 없으면 회귀 점수 순서·규칙 기반으로 graceful fallback
OPENAI_API_KEY=
OPENAI_MODEL_SELECTOR=gpt-4o-mini
OPENAI_MODEL_GRAMMAR=gpt-4o-mini
OPENAI_MODEL_REPORT=gpt-4o-mini

# ===== Stable Diffusion (Stability AI) — 이미지 생성 =====
STABILITY_API_KEY=
STABILITY_API_URL=https://api.stability.ai/v2beta/stable-image/generate/core
IMAGE_OUTPUT_DIR=generated/images

# ===== Naver Clova Voice — TTS =====
CLOVA_CLIENT_ID=
CLOVA_CLIENT_SECRET=
CLOVA_TTS_URL=https://naveropenapi.apigw.ntruss.com/tts-premium/v1/tts
AUDIO_OUTPUT_DIR=generated/audio

# ===== 학습된 회귀 모델 가중치 저장 경로 =====
MODEL_DIR=models
